# ============================================
# LenteraPustaka Microservices — Environment Variables
# ============================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke repository!

# ---- GENERAL ----
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ---- AUTH SERVICE (Port 8001) ----
# Gunakan DATABASE_URL di Railway untuk masing-masing service
# Contoh untuk koneksi lokal (jika tidak menggunakan docker):
# DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5433/auth_db
SECRET_KEY=CHANGE_ME_USE_RANDOM_STRING_MIN_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- LIBRARY SERVICE (Port 8002) ----
# Contoh untuk koneksi lokal (jika tidak menggunakan docker):
# DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5434/item_db
AUTH_SERVICE_URL=http://auth-service:8001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- DATABASE (Khusus Docker-Compose) ----
POSTGRES_PASSWORD=CHANGE_ME

# ---- FRONTEND ----
# URL Backend yang akan dihubungi oleh Frontend
VITE_AUTH_API_URL=http://localhost:8001
VITE_LIBRARY_API_URL=http://localhost:8002